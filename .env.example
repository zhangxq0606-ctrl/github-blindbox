# ============================================================================
# GitHub 每日盲盒 — 本地开发环境变量样例
# ============================================================================
# 复制本文件为 .env 并填入真实值。.env 已在 .gitignore 中，不会被提交。
#
# 配置前必读 GUIDE.md。
#
# 本地跑通用：在项目根目录执行
#   cp .env.example .env
#   (编辑 .env 填入下面的值)
#   cat trending-feed.json | node scripts/github-digest.js > digest.txt
#   cat digest.txt | node scripts/send-email.js --to 你的QQ邮箱
#
# GitHub Actions 部署用：把下面的值配到仓库 Settings → Secrets and variables → Actions
# ============================================================================

# ---------------------------------------------------------------------------
# LLM API Key（推荐 DeepSeek 官方，省事）
# ---------------------------------------------------------------------------
# DeepSeek 官方（默认推荐）：去 https://platform.deepseek.com/api_keys 创建
#   新用户有免费额度，无需信用卡，注册即用
# 阿里云百炼（备选，服务器用这个）：去 https://bailian.console.aliyun.com/ 创建
#   注意是「API Key 管理」里的 sk- Key，不是阿里云主账号 AK/SK
ANTHROPIC_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---------------------------------------------------------------------------
# LLM API Base URL（根据 Key 的来源选一个）
# ---------------------------------------------------------------------------
# 选项 A：DeepSeek 官方（默认推荐，fork 用户直接用这个，不用改）
# 注意：DeepSeek 官方不带 /v1 后缀，直接 https://api.deepseek.com
ANTHROPIC_BASE_URL=https://api.deepseek.com
#
# 选项 B：阿里云百炼 — 通用端点（个人用户）
# 末尾必须带 /compatible-mode/v1，少了会 404
# ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#
# 选项 C：阿里云百炼 — 业务空间专属端点（企业/高级用户，服务器用这个）
# ANTHROPIC_BASE_URL=https://<业务空间id>.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
#
# 选项 D：其他兼容 OpenAI /chat/completions 格式的厂商
# ANTHROPIC_BASE_URL=https://api.siliconflow.cn/v1
# ANTHROPIC_BASE_URL=https://api.moonshot.cn/v1

# ---------------------------------------------------------------------------
# 模型名（默认 deepseek-v4-flash，DeepSeek 官方和阿里云百炼上都叫这个名）
# ---------------------------------------------------------------------------
# DeepSeek 官方支持：deepseek-v4-flash / deepseek-v4-pro
# 阿里云百炼支持：deepseek-v4-flash / qwen3.6-flash 等
ANTHROPIC_MODEL=deepseek-v4-flash
#
# 其他厂商举例（换了端点同步改模型名）：
# SiliconFlow：deepseek-ai/DeepSeek-V3
# 月之暗面：moonshot-v1-8k

# ---------------------------------------------------------------------------
# QQ 邮箱（同时作为发件邮箱 + 默认收件邮箱）
# ---------------------------------------------------------------------------
QQ_EMAIL=123456789@qq.com

# ---------------------------------------------------------------------------
# QQ 邮箱授权码（不是 QQ 密码！）
# ---------------------------------------------------------------------------
# 获取：QQ 邮箱网页版 → 设置 → 账号与安全 → IMAP/SMTP 服务 → 开启 → 发短信验证 → 拿 16 位授权码
QQ_SMTP_AUTH_CODE=xxxxxxxxxxxxxxxx
